generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SongStatus {
  learning
  want_to_learn
  learned
  paused
}

model Folder {
  id        String       @id @default(cuid())
  userId    String
  name      String
  color     String       @default("#0d9488")
  imageUrl  String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  songs     SongFolder[]

  @@index([userId])
}

model Song {
  id          String             @id @default(cuid())
  userId      String
  title       String
  artist      String
  genre       String             @default("")
  instrument  String             @default("")
  difficulty  Int                @default(1)
  status      SongStatus         @default(want_to_learn)
  notes       String             @default("")
  imageUrl    String?
  videoUrl    String?
  tabUrl      String?
  accentColor String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  folders     SongFolder[]
  sessions    PracticeSession[]

  @@index([userId])
}

model SongFolder {
  songId    String
  folderId  String
  createdAt DateTime @default(now())
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  folder    Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@id([songId, folderId])
  @@index([songId])
  @@index([folderId])
}

model PracticeSession {
  id        String   @id @default(cuid())
  songId    String
  date      DateTime @default(now())
  minutes   Int
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([songId])
  @@index([date])
}
